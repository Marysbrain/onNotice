---
import Base from "../layouts/Base.astro";
// Pagefind search. The index and UI bundle are generated by `pagefind --site
// dist` after the Astro build, and served from /pagefind on the same origin.
// No server, no cost. In `astro dev` the /pagefind assets do not exist yet, so
// run a full build and preview to test search.
---

<Base
  title="Search"
  description="Search the evidence library, methodology, corrections, and take action pages. Runs in your browser. No server."
>
  <div class="wrap prose">
    <h1>Search</h1>
    <p>
      Search the evidence library, the methodology, the corrections page, and
      the take action pages. The search runs entirely in your browser with no
      server and no tracking.
    </p>
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <div id="search" aria-label="Site search"></div>
    <noscript>
      <p>Search needs JavaScript. You can still browse the
        <a href="/library">library</a> and the
        <a href="/methodology">methodology</a> directly.</p>
    </noscript>
  </div>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      if (window.PagefindUI) {
        new window.PagefindUI({ element: "#search", showSubResults: true });
      }
    });
  </script>
</Base>
